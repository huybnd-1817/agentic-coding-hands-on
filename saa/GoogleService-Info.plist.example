<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  GoogleService-Info.plist.example
  ─────────────────────────────────────────────────────────────────────────────
  This is a sanitized example. Copy to GoogleService-Info.plist (no .example),
  then replace every REPLACE_ME_* placeholder with values from your Google Cloud
  OAuth client (iOS type) for the com.sun-asterisk.saa bundle ID.

  Steps:
    1. Google Cloud Console → APIs & Services → Credentials
    2. Create OAuth 2.0 Client ID → Application type: iOS
    3. Bundle ID: com.sun-asterisk.saa
    4. Download the generated .plist and drop it into the saa/ folder in Xcode
       (drag into the project navigator so it is added to the saa target)
    5. Copy REVERSED_CLIENT_ID into saa/Info.plist → CFBundleURLTypes → CFBundleURLSchemes

  GoogleService-Info.plist is gitignored — never commit it.
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_ME_CLIENT_ID.apps.googleusercontent.com</string>

	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.REPLACE_ME_CLIENT_ID</string>

	<key>BUNDLE_ID</key>
	<string>com.sun-asterisk.saa</string>

	<key>PROJECT_ID</key>
	<string>REPLACE_ME_PROJECT_ID</string>

	<key>GOOGLE_APP_ID</key>
	<string>REPLACE_ME_GOOGLE_APP_ID</string>

	<key>IS_SIGNIN_ENABLED</key>
	<string>1</string>
</dict>
</plist>
