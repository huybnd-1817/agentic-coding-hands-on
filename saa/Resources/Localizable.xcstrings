    "home.theme.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Root Further is a concept that encourages everyone to not only grow on the surface, but also to develop deeply — to strengthen foundational values, professional expertise, and meaningful connections within the Sun* community."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Root Further là khái niệm khuyến khích mọi người không chỉ phát triển trên bề mặt mà còn phát triển sâu hơn — củng cố các giá trị nền tảng, chuyên môn nghề nghiệp và những kết nối có ý nghĩa trong cộng đồng Sun*."
          }
        }
      }
    },
