#----------------------------------------------------------
# Supabase Environment Variables
#
# Copy this file to `.env` (gitignored) and fill in real values.
# `supabase start` reads .env at the repo root and substitutes
# env(NAME) references in supabase/config.toml.
#----------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

#----------------------------------------------------------
# Google OAuth — REQUIRED for local Google Sign-In to work.
#
# GOOGLE_CLIENT_ID must be the iOS OAuth client ID (the
# `CLIENT_ID` field inside saa/GoogleService-Info.plist).
# It is NOT secret — it ships in the app bundle.
#
# GoTrue compares the ID token's `aud` claim against this
# value. A placeholder here causes step 4 of sign-in
# (Exchange ID token with Supabase) to fail with
# `400 Bad ID token`.
#
# GOOGLE_CLIENT_SECRET is required by config syntax but
# unused by the native signInWithIdToken flow — any
# non-empty value works for local dev.
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
